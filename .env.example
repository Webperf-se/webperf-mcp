# Your personal premium API key for api.webperf.se.
# This stays on YOUR machine — it is read by the local MCP server process
# and sent only to https://api.webperf.se as the `api-key` header.
WEBPERF_API_KEY=your-premium-api-key-here

# Optional overrides (sensible defaults shown)
# WEBPERF_API_BASE=https://api.webperf.se
# WEBPERF_HTTP_TIMEOUT=30
